generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  contact       String?
  favoriteDrink String?
  tags          String[]
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("customers")
}

model PromoCache {
  id        String   @id @default(cuid())
  data      Json
  createdAt DateTime @default(now())

  @@map("promo_cache")
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  sessionId String
  createdAt DateTime @default(now())

  @@map("chat_messages")
}
